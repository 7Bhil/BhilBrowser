{
  "name": "bhilbrowser",
  "productName": "BhilBrowser",
  "version": "1.0.0",
  "description": "A sleek, modern Electron-based web browser",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/7Bhil/BhilBrowser.git"
  },
  "scripts": {
    "start": "electron --no-sandbox .",
    "build:css": "npx tailwindcss -i ./src/input.css -o ./src/style.css --watch",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["browser", "electron", "bhilbrowser"],
  "author": "7Bhil",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.7bhil.bhilbrowser",
    "productName": "BhilBrowser",
    "copyright": "Copyright © 2025 7Bhil",
    "icon": "icon.png",
    "files": [
      "src/**/*",
      "main.js",
      "package.json",
      "icon.png"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png",
      "category": "Network;WebBrowser",
      "desktop": {
        "Name": "BhilBrowser",
        "Comment": "A modern, sleek web browser",
        "Categories": "Network;WebBrowser;"
      }
    },
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "icon.png"
    },
    "mac": {
      "target": [{"target": "dmg", "arch": ["x64", "arm64"]}],
      "icon": "icon.png",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron/remote": "^2.1.3",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
